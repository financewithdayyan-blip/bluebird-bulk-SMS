# Zoom Phone SMS — copy these into .env.local with real values
# (Zoom App Marketplace → Develop → Build App → Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Your Zoom Phone number in E.164 format, e.g. +12145550000
ZOOM_FROM_NUMBER=
# Email of the Zoom user the number is assigned to (or set ZOOM_USER_ID instead)
ZOOM_USER_EMAIL=
